# ClauseLens configuration — copy to `.env` and fill in. NEVER commit the real .env.
# Every setting is validated at startup by backend/app/config.py (pydantic-settings).

# ---- LLM provider (Gemini free tier) ----------------------------------------
# Get a free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-key-here

# Model routing: cheap model for simple/extractive work, strong for reasoning.
# Both are free-tier on Google AI Studio as of 2026.
MODEL_CHEAP=gemini-2.5-flash-lite
MODEL_STRONG=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# ---- Vector store -----------------------------------------------------------
# "faiss" = local file index (zero infra, default for dev).
# "pgvector" = Postgres/Supabase (used in deploy). Set DATABASE_URL when pgvector.
VECTOR_BACKEND=faiss
FAISS_INDEX_DIR=data/index
# DATABASE_URL=postgresql://user:pass@host:5432/postgres   # required if pgvector

# ---- Retrieval tuning -------------------------------------------------------
RETRIEVAL_TOP_K=8          # candidates pulled from each retriever arm
RERANK_TOP_N=4             # passages kept after cross-encoder rerank
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# ---- Observability ----------------------------------------------------------
LOG_DIR=backend/app/observability/logs
LOG_LEVEL=INFO

# ---- App --------------------------------------------------------------------
MAX_UPLOAD_MB=15
CORS_ORIGINS=http://localhost:5173
ENV=local
